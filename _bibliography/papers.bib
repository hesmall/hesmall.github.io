@article{ozernov-palchik_precision_2025,
	title = {Precision {fMRI} reveals that the language network exhibits adult-like left-hemispheric lateralization by 4 years of age},
	issn = {2692-8205},
	doi = {10.1101/2024.05.15.594172},
	abstract = {In adults, left hemisphere (LH) damage often leads to aphasia, but many cases of early damage leave linguistic processing intact, with a functional language system developing in the right hemisphere. To explain this early apparent equipotentiality of the two hemispheres for language, some have proposed that the language system is more bilateral during early development and becomes increasingly left-lateralized with age. We examined language lateralization using fMRI in two large developmental cohorts (total n=273 children aged 4-16 years; n=107 adults). Strong, adult-like LH lateralization (in response magnitude and activation volume) was evident by age 4, although other features of the LH language network showed protracted development, including the magnitude of language response and the strength of functional connectivity. Thus, although the RH can take over language function in some cases of early brain damage, this plasticity occurs in spite of adult-level LH bias present by age 4 years.},
	language = {eng},
	journal = {bioRxiv: The Preprint Server for Biology},
	author = {Ozernov-Palchik, O. and O'Brien, A.M. and Lee, E. and Richardson, H. and Romeo, R. and Poliak, M. and Lipkin, B. and \textbf{Hannah Small} and Capella, J. and Nieto-Castañón, A. and Saxe, R. and Gabrieli, J.D.E. and Fedorenko, E.},
	month = sep,
	year = {2025},
	keywords = {development, fMRI, language, language network, lateralization},
	pages = {2024.05.15.594172},
	file = {Submitted Version:/Users/hsmall2/Zotero/storage/B4P5ZVRK/Ozernov-Palchik et al. - 2025 - Precision fMRI reveals that the language network exhibits adult-like left-hemispheric lateralization.pdf:application/pdf},
}

